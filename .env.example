# Serverless Postgres (Neon) connection string
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# football-data.org API token (free tier) — server-side only, never exposed to the browser
# Get one at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN="your-token-here"

# iron-session cookie encryption password — must be at least 32 characters
# Generate: openssl rand -base64 32
SESSION_PASSWORD="change-me-to-a-random-string-at-least-32-chars"

# Protects the /api/cron/sync endpoint. Vercel Cron sends it as a Bearer token.
# Generate: openssl rand -hex 16
CRON_SECRET="change-me"

# Comma-separated display names that should be seeded as admins (used by the seed script)
ADMIN_NAMES="Berker"
